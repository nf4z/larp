		maxPetsEquipped = math.max(1, math.floor(tonumber(statsModule:GetMaxPetsEquipped(playerData)) or 13))
	end)
	local selectedPetIds = {}
	local selectedPetIdSet = {}
	local selectedSuperCount = 0
	for _, candidate in ipairs(candidates) do
		if #selectedPetIds >= maxPetsEquipped then
			break
		end
		local petId = tostring(candidate.pet.Id or "")
		local isSuperLegendary = candidate.pet.Super == true or candidate.pet.IsSuper == true
		if petId ~= "" and (not isSuperLegendary or selectedSuperCount < maxSupersEquipped) then
			table.insert(selectedPetIds, petId)
			selectedPetIdSet[petId] = true
			if isSuperLegendary then
				selectedSuperCount += 1
			end
		end
	end
	local equippedPetIds = getEnchantablePets()
	local teamMatches = #equippedPetIds == #selectedPetIds
	if teamMatches then
		for _, petId in ipairs(equippedPetIds) do
			if not selectedPetIdSet[tostring(petId)] then
				teamMatches = false
				break
			end
		end
	end
	if teamMatches then
		return true
	end
	if tick() - (tonumber(activeStates.BGSI_Lite_LastAutoEnchantTeamAttempt) or 0) < 4 then
		return false
	end
	activeStates.BGSI_Lite_LastAutoEnchantTeamAttempt = tick()
	local equippedPetIdSet = {}
	for _, petId in ipairs(equippedPetIds) do
		local normalizedPetId = tostring(petId)
		equippedPetIdSet[normalizedPetId] = true
		if not selectedPetIdSet[normalizedPetId] then
			remoteEvent:FireServer("UnequipPet", petId)
		end
	end
	for _, petId in ipairs(selectedPetIds) do
		if not equippedPetIdSet[petId] then
			remoteEvent:FireServer("EquipPet", petId)
		end
	end
	local equipDeadline = tick() + 4
	repeat
		task.wait(0.2)
		equippedPetIds = getEnchantablePets()
		equippedPetIdSet = {}
		for _, petId in ipairs(equippedPetIds) do
			equippedPetIdSet[tostring(petId)] = true
		end
		teamMatches = #equippedPetIds == #selectedPetIds
		for _, petId in ipairs(selectedPetIds) do
			if not equippedPetIdSet[petId] then
				teamMatches = false
				remoteEvent:FireServer("EquipPet", petId)
			end
		end
	until teamMatches or tick() >= equipDeadline
	return teamMatches
end
local autoEnchantThreadRunning = false
-- Auto enchant loop: rerolls equipped pets until the target enchant setup is found.
local function getEnchantTargetList()
	if autoEnchantThreadRunning then
		return
	end
	Config.equippedTargetEnchant = "secret-hunter"
	Config.equippedTargetEnchant2 = "ultra-roller"
	autoEnchantThreadRunning = true
	task.spawn(function()
		while Config.autoEnchant do
			if not prepareAutoEnchantTeam() then
				task.wait(0.5)
				continue
			end
			local targetEnchantOne = "secret-hunter"
			local targetEnchantTwo = "ultra-roller"
			local targetEnchantLevel = tonumber(Config.equippedTargetEnchantLevel) or 0
			local selectedEnchantCurrencyMode = Config.equippedEnchantCurrency
				or "Auto (Secret = Crystals,Normal = Gems)"
			local hasSecondEnchantTarget = targetEnchantTwo ~= "" and targetEnchantTwo ~= "(None - single target)"
			local equippedPetIds = getEnchantablePets()
			for loopSlotH, equippedPetId in ipairs(equippedPetIds) do
				if not Config.autoEnchant then
					break
				end
				local petData = getEnchantCurrency(equippedPetId)
				if petData and petData.Super ~= true and petData.IsSuper ~= true then
					local canUseDualEnchant = canPetUseDualEnchantMode(petData)
					while Config.autoEnchant do
						petData = getEnchantCurrency(equippedPetId)
						if not petData then
							break
						end
						local hasTargetEnchantOne = getPetEnchantInfo(petData, targetEnchantOne, targetEnchantLevel)
						local hasTargetEnchantTwo = hasSecondEnchantTarget
								and getPetEnchantInfo(petData, targetEnchantTwo, targetEnchantLevel)
							or nil
						local targetEnchantSatisfied = false
						if hasSecondEnchantTarget and canUseDualEnchant then
							targetEnchantSatisfied = (hasTargetEnchantOne and hasTargetEnchantTwo) and true or false
						elseif hasSecondEnchantTarget then
							targetEnchantSatisfied = (hasTargetEnchantOne or hasTargetEnchantTwo) and true or false
						else
							targetEnchantSatisfied = hasTargetEnchantOne ~= nil
						end
						if targetEnchantSatisfied then
							break
						end
						local currentSlotForTargetOne = findPetEnchantSlot(petData, targetEnchantOne)
						local currentSlotForTargetTwo = hasSecondEnchantTarget
								and findPetEnchantSlot(petData, targetEnchantTwo)
							or nil
						local rerollSlot = nil
						local targetEnchantForCurrency = targetEnchantOne
						if hasSecondEnchantTarget and canUseDualEnchant then
							if currentSlotForTargetOne and not currentSlotForTargetTwo then
								rerollSlot = currentSlotForTargetOne
								targetEnchantForCurrency = targetEnchantTwo
							end
							if currentSlotForTargetTwo and not currentSlotForTargetOne then
								rerollSlot = currentSlotForTargetTwo
								targetEnchantForCurrency = targetEnchantOne
							end
						end
						local resolvedEnchantCurrency =
							resolveEnchantCurrency(selectedEnchantCurrencyMode, targetEnchantForCurrency)
						if resolvedEnchantCurrency == "Shadow Crystals" then
							pcall(function()
								remoteEvent:FireServer("UseShadowCrystal", equippedPetId, rerollSlot)
							end)
						elseif resolvedEnchantCurrency == "Reroll Orbs" then
							pcall(function()
								remoteFunction:InvokeServer("RerollEnchants", equippedPetId, "Powerup", rerollSlot)
							end)
						else
							pcall(function()
								remoteFunction:InvokeServer("RerollEnchants", equippedPetId, "Gems", rerollSlot)
							end)
						end
						task.wait(0.55)
						if not Config.autoEnchant then
							break
						end
						petData = getEnchantCurrency(equippedPetId)
						if petData then
							hasTargetEnchantOne = getPetEnchantInfo(petData, targetEnchantOne, targetEnchantLevel)
							hasTargetEnchantTwo = hasSecondEnchantTarget
									and getPetEnchantInfo(petData, targetEnchantTwo, targetEnchantLevel)
								or nil
							local targetSatisfiedAfterReroll = false
							if hasSecondEnchantTarget and canUseDualEnchant then
								targetSatisfiedAfterReroll = (hasTargetEnchantOne and hasTargetEnchantTwo) and true
									or false
							elseif hasSecondEnchantTarget then
								targetSatisfiedAfterReroll = (hasTargetEnchantOne or hasTargetEnchantTwo) and true
									or false
							else
								targetSatisfiedAfterReroll = hasTargetEnchantOne ~= nil
							end
							if targetSatisfiedAfterReroll then
								break
							end
						end
						task.wait(0.2)
					end
				end
				task.wait(0.05)
			end
			task.wait(0.3)
		end
		autoEnchantThreadRunning = false
	end)
end
