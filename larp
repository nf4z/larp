		local riftInfoEntry = type(riftData) == "table" and riftData[riftObject.Name] or nil
		if type(riftInfoEntry) == "table" then
			if riftInfoEntry.Type == "Egg" and riftTextLooksLikeDoodleEgg(riftInfoEntry.Egg) then
